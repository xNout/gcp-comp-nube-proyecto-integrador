<div class="max-w-6xl mx-auto px-4 py-12">
  <div class="text-center mb-12">
    <h1 class="text-4xl font-extrabold text-[var(--color-text-primary)] mb-4">
      <%= MESSAGES.home.heroTitle %>
    </h1>
    <p class="text-lg text-[var(--color-text-secondary)] max-w-2xl mx-auto">
      <%= MESSAGES.home.heroSubtitle %>
    </p>
  </div>

  <div class="grid gap-6 md:grid-cols-3 mb-12">
    <div class="bg-white rounded-[var(--radius-xl)] p-6 border border-[var(--color-border-soft)]" style="box-shadow: var(--shadow-card);">
      <div class="w-12 h-12 rounded-[var(--radius-lg)] bg-orange-100 flex items-center justify-center mb-4">
        <svg class="w-6 h-6 text-[var(--color-primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 01-2 2v4a2 2 0 012 2h14a2 2 0 012-2v-4a2 2 0 01-2-2m-2-4h.01M17 16h.01"></path></svg>
      </div>
      <h3 class="text-lg font-semibold text-[var(--color-text-primary)] mb-2"><%= MESSAGES.home.cardComputeTitle %></h3>
      <p class="text-sm text-[var(--color-text-secondary)]"><%= MESSAGES.home.cardComputeDesc %></p>
    </div>

    <div class="bg-white rounded-[var(--radius-xl)] p-6 border border-[var(--color-border-soft)]" style="box-shadow: var(--shadow-card);">
      <div class="w-12 h-12 rounded-[var(--radius-lg)] bg-orange-100 flex items-center justify-center mb-4">
        <svg class="w-6 h-6 text-[var(--color-primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"></path></svg>
      </div>
      <h3 class="text-lg font-semibold text-[var(--color-text-primary)] mb-2"><%= MESSAGES.home.cardStorageTitle %></h3>
      <p class="text-sm text-[var(--color-text-secondary)]"><%= MESSAGES.home.cardStorageDesc %></p>
    </div>

    <div class="bg-white rounded-[var(--radius-xl)] p-6 border border-[var(--color-border-soft)]" style="box-shadow: var(--shadow-card);">
      <div class="w-12 h-12 rounded-[var(--radius-lg)] bg-orange-100 flex items-center justify-center mb-4">
        <svg class="w-6 h-6 text-[var(--color-primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
      </div>
      <h3 class="text-lg font-semibold text-[var(--color-text-primary)] mb-2"><%= MESSAGES.home.cardMonitoringTitle %></h3>
      <p class="text-sm text-[var(--color-text-secondary)]"><%= MESSAGES.home.cardMonitoringDesc %></p>
    </div>
  </div>

  <div class="flex justify-center gap-4">
    <a href="<%= CONFIG.routes.upload %>" class="inline-flex items-center justify-center px-6 py-3 rounded-[var(--radius-lg)] text-white font-semibold bg-[var(--color-primary)] hover:bg-[var(--color-primary-hover)] transition" style="box-shadow: var(--shadow-soft);">
      <%= MESSAGES.home.buttonUpload %>
    </a>
    <a href="<%= CONFIG.routes.evidences %>" class="inline-flex items-center justify-center px-6 py-3 rounded-[var(--radius-lg)] font-semibold border-2 border-[var(--color-primary)] text-[var(--color-primary)] hover:bg-orange-50 transition">
      <%= MESSAGES.home.buttonList %>
    </a>
  </div>
</div>
